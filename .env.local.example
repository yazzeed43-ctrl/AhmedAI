# انسخ هذا الملف إلى .env.local (محلياً) واملأ القيم الحقيقية
# نفس المتغيرات لازم تُضاف أيضاً في إعدادات Environment Variables على Vercel

# قاعدة بيانات أحمد/فهد الرئيسية (مشروع Supabase الرئيسي)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=

# مفتاح Anthropic Claude API
ANTHROPIC_API_KEY=

# مفتاح Finnhub (بيانات أسهم فهد)
FINNHUB_API_KEY=

# مفتاح anon الخاص بـ Edge Function رهف (مشروع Supabase منفصل: bbxbyuygtazscfhbonls)
RAHAF_ANON_KEY=

# مفتاح anon الخاص بـ Edge Function staging-data (مشروع Supabase منفصل: mxjwwdedtfbksitobjhj)
STAGING_ANON_KEY=
